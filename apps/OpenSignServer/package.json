{
  "name": "open_sign_server",
  "version": "2.37.0",
  "description": "opensign server using the parse-server module",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenSignLabs/OpenSign"
  },
  "license": "MIT",
  "main": "index.js",
  "scripts": {
    "coverage": "TESTING=true nyc jasmine",
    "lint": "eslint --cache ./cloud && eslint --cache index.js && eslint --cache ./spec",
    "lint-fix": "eslint --cache --fix ./cloud && eslint --cache --fix index.js && eslint --cache --fix ./spec",
    "prettier": "prettier --write '{cloud,spec}/{**/*,*}.js' 'index.js'",
    "start": "node index.js",
    "test": "TESTING=true USE_LOCAL=true SERVER_URL=http://localhost:8080/app mongodb-runner exec -- jasmine",
    "test:security": "TESTING=true USE_LOCAL=true SERVER_URL=http://localhost:8080/app node dependency-security.test.mjs",
    "watch": "nodemon index.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@aws-sdk/s3-request-presigner": "^3.1008.0",
    "@parse/fs-files-adapter": "^3.0.0",
    "@parse/push-adapter": "^8.5.0",
    "@parse/s3-files-adapter": "5.0.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@signpdf/placeholder-pdf-lib": "^3.3.0",
    "@signpdf/signer-p12": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "axios": "^1.18.1",
    "coherentpdf": "^2.5.5",
    "cors": "^2.8.6",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "form-data": "^4.0.6",
    "generate-api-key": "^1.0.2",
    "googleapis": "^171.4.0",
    "libreoffice-convert": "^1.8.1",
    "mailgun.js": "^12.7.1",
    "moment": "^2.30.1",
    "mongodb": "^7.1.0",
    "multer": "^2.2.0",
    "multer-s3": "^3.0.1",
    "node-forge": "^1.4.0",
    "nodemailer": "^9.0.3",
    "p-limit": "^7.3.0",
    "parse": "^8.6.0",
    "parse-dbtool": "^1.2.0",
    "parse-server": "^9.10.0",
    "parse-server-api-mail-adapter": "^5.0.5",
    "pdf-lib": "^1.17.1",
    "posthog-node": "^5.21.2",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^9.1.1",
    "sharp": "^0.34.5",
    "speakeasy": "^2.0.0",
    "stripe": "^22.1.1",
    "ws": "^8.21.1"
  },
  "type": "module",
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "eslint": "^9.39.4",
    "jasmine": "^6.1.0",
    "mongodb-runner": "^6.7.1",
    "nodemon": "^3.1.14",
    "nyc": "^17.1.0",
    "prettier": "^3.8.1"
  },
  "overrides": {
    "ws": "$ws",
    "parse": "$parse",
    "form-data": "$form-data",
    "@parse/push-adapter": "$@parse/push-adapter",
    "@grpc/grpc-js": "^1.14.4",
    "fast-xml-builder": "1.2.0",
    "fast-xml-parser": "^5.7.0",
    "lodash": "^4.17.24",
    "node-forge": "^1.4.0",
    "picomatch": "^2.3.2",
    "protobufjs": "^7.6.3",
    "tmp": "^0.2.7",
    "undici": "^7.28.0",
    "websocket-driver": "^0.7.5"
  },
  "engines": {
    "node": ">=20.19.0 <21 || >=22.13.0 <23 || >=24.11.0 <25"
  }
}
