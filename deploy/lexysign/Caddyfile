sign.lexyalgo.com {
  encode zstd gzip

  @uts_exports path /v1/exports/* /v1/reverse-etl/*
  handle @uts_exports {
    reverse_proxy uts-ingestion-api:8788
  }

  handle_path /api/* {
    reverse_proxy lexysign-server:8080
  }

  reverse_proxy lexysign-client:3000
}

