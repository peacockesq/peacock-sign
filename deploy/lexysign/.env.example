# LexySign production-ish environment template.
# Copy to .env on the server. Do not commit real values.

# Public origin. Suggested: https://sign.lexyalgo.com once DNS points at 37.27.49.209.
HOST_URL=https://sign.lexyalgo.com
PUBLIC_URL=https://sign.lexyalgo.com

# OpenSign/Parse app id must remain opensign unless the client/server are migrated together.
APP_ID=opensign
REACT_APP_APPID=opensign
REACT_APP_FORCE_DRAWN_SIGNATURES=true
APP_NAME=LexySign
appName=LexySign
GENERATE_SOURCEMAP=false

# Generate on the server:
#   openssl rand -base64 36
MASTER_KEY=REPLACE_WITH_RANDOM_MASTER_KEY

# Local Mongo inside compose.
MONGODB_URI=mongodb://mongo:27017/lexysign
DATABASE_URI=mongodb://mongo:27017/lexysign
SERVER_URL=https://sign.lexyalgo.com/api/app
PARSE_MOUNT=/app
USE_LOCAL=true

# SMTP: required before real users. For smoke test, use a sandbox/capture route and say so.
SMTP_ENABLE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_USER_EMAIL=
SMTP_PASS=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_SENDER=
EMAIL_FOOTER_HTML=

# Required for OpenSign PDF signing. Test cert is acceptable only for smoke tests.
# Generate throwaway test cert on the server with scripts/deploy/lexysign-generate-env.sh.
PFX_BASE64=REPLACE_WITH_BASE64_P12
PASS_PHRASE=REPLACE_WITH_P12_PASSWORD

# Optional object storage later. Local files are mounted at lexysign-files for MVP smoke testing.
DO_ENDPOINT=
DO_SPACE=
DO_BASEURL=
DO_REGION=
DO_ACCESS_KEY_ID=
DO_SECRET_ACCESS_KEY=
